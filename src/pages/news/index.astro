---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getUnifiedNews } from "../../lib/content";

const allNews = await getUnifiedNews();
---

<BaseLayout title="お知らせ | ojochiの作業部屋">
	<section class="section">
		<h1>お知らせ一覧</h1>
		<article class="card news-list-card">
			{
				allNews.map((item) => (
					<div class="news-list-item" id={item.slug}>
						<p class="card-date">
							{item.date.toLocaleDateString("ja-JP", {
								year: "numeric",
								month: "2-digit",
								day: "2-digit",
							})}
						</p>
						<p class="card-description">{item.description}</p>
						{
							item.link && (
								<p class="news-link-wrap">
									<a class="news-link" href={item.link}>
										ブログを読む
									</a>
								</p>
							)
						}
					</div>
				))
			}
		</article>
	</section>
</BaseLayout>
