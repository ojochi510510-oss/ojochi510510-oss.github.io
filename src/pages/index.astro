---
import Card from "../components/Card.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllBlog, getUnifiedNews } from "../lib/content";

const [allNews, allBlog] = await Promise.all([getUnifiedNews(), getAllBlog()]);
const latestNews = allNews.slice(0, 3);
const latestBlog = allBlog.slice(0, 5);
const BASE_URL = import.meta.env.BASE_URL;
const resolveLink = (link: string) =>
	link.startsWith("/") ? `${BASE_URL}${link.slice(1)}` : link;
---

<BaseLayout
	title="ojochiの作業部屋"
	description="作業記録と更新情報を静かに整理した個人サイトです。"
>
	<section class="hero">
		<div class="hero-copy">
			<p class="hero-kicker">ojochi archive</p>
			<h1>作業記録と更新履歴を、落ち着いた形で整理しています。</h1>
			<p class="hero-summary">必要な更新だけを短く追えて、記事はあとから静かに辿れる構成です。</p>
		</div>
		<div class="hero-panel">
			<p class="hero-panel-label">Contents</p>
			<ul class="hero-stats">
				<li>
					<strong>{allNews.length}</strong>
					<span>お知らせ</span>
				</li>
				<li>
					<strong>{allBlog.length}</strong>
					<span>ブログ記事</span>
				</li>
			</ul>
			<div class="hero-actions">
				<a class="button-link" href={`${BASE_URL}news/`}>更新一覧</a>
				<a class="button-link button-link-secondary" href={`${BASE_URL}blog/`}>記事一覧</a>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="section-head">
			<div>
				<p class="section-kicker">Update feed</p>
				<h2>お知らせ</h2>
			</div>
			<a href={`${BASE_URL}news/`}>一覧を見る</a>
		</div>
		<article class="card news-summary-card">
			{
				latestNews.length > 0 ? (
					<ul class="news-summary-list">
						{latestNews.map((item) => (
							<li class="news-summary-item">
								<p class="card-date">
									{item.date.toLocaleDateString("ja-JP", {
										year: "numeric",
										month: "2-digit",
										day: "2-digit",
									})}
								</p>
								<p class="card-description">{item.description}</p>
								{
									item.link && (
										<p class="news-link-wrap">
											<a class="news-link" href={resolveLink(item.link)}>
												詳細を見る
											</a>
										</p>
									)
								}
							</li>
						))}
					</ul>
				) : (
					<p class="card-description">まだお知らせはありません。</p>
				)
			}
		</article>
	</section>

	<section class="section">
		<div class="section-head">
			<div>
				<p class="section-kicker">Recent posts</p>
				<h2>Blog</h2>
			</div>
			<a href={`${BASE_URL}blog/`}>一覧を見る</a>
		</div>
		<div class="cards">
			{
				latestBlog.map((item) => (
					<Card
						href={`${BASE_URL}blog/${item.slug}/`}
						title={item.data.title}
						date={item.data.date}
						description={item.data.description}
					/>
				))
			}
		</div>
	</section>
</BaseLayout>
