---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<header class="site-header">
	<div class="container header-inner">
		<p class="site-title"><a href="/">{title}</a></p>
		<nav class="site-nav" aria-label="メインナビゲーション">
			<a href="/news">News</a>
			<a href="/blog">Blog</a>
		</nav>
	</div>
</header>
