---
interface Props {
	href: string;
	title: string;
	date: Date;
	description: string;
}

const { href, title, date, description } = Astro.props;
const dateLabel = date.toLocaleDateString("ja-JP", {
	year: "numeric",
	month: "2-digit",
	day: "2-digit",
});
---

<article class="card">
	<h3 class="card-title"><a href={href}>{title}</a></h3>
	<p class="card-date">{dateLabel}</p>
	<p class="card-description">{description}</p>
</article>
